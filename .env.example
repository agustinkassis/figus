# ─── FIGUS — Mundial 2026 Sticker Album ──────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Album identity ────────────────────────────────────────────────────────────

# Unique slug that identifies this album on Nostr (used as the "d" tag).
NEXT_PUBLIC_ALBUM_ID=mundial-2026

# ── Issuer keypair ────────────────────────────────────────────────────────────
# The issuer is the trusted server that mints packs, grants ownership, and
# settles P2P trades. Run `npm run seed` once to generate the keypair.

# Issuer public key in hex (printed by `npm run seed`). Exposed to the browser
# so the client can filter authoritative Nostr events.
NEXT_PUBLIC_ISSUER_PUBKEY=

# Issuer private key in nsec or hex format. KEEP SECRET — server-side only.
ISSUER_NSEC=

# ── Lightning ─────────────────────────────────────────────────────────────────

# Lightning address that receives zap payments for pack purchases and prizes.
# Format: user@domain.tld
NEXT_PUBLIC_ISSUER_LN_ADDRESS=

# Nostr Wallet Connect string for the issuer to pay rewards automatically.
# Format: nostr+walletconnect://... (get it from Alby Hub, Primal, etc.)
# Optional — if unset, rewards are paid manually via Lightning invoice.
REWARD_NWC=

# NWC de la wallet RECEPTORA del issuer — emite y cobra las facturas de los
# sobres/compras (Fix #1, Opción A). Debe soportar make_invoice y lookup_invoice
# (Alby Hub lo soporta). Si no se setea, cae a REWARD_NWC.
ISSUER_NWC=

# Modo de pagos del issuer. Vacío = producción (usa ISSUER_NWC/REWARD_NWC).
# "mock" = SOLO para tests: las facturas se autoconfirman sin sats reales.
ISSUER_PAYMENTS=

# Cada cuánto el issuer revisa si las facturas pendientes se pagaron (ms).
ORDER_POLL_MS=6000

# Modo de pagos de PREMIOS (página/álbum completos). Vacío = producción (paga
# vía REWARD_NWC). "mock" = SOLO para tests: registra el reclamo sin pagar sats.
REWARD_PAYMENTS=

# Sats awarded when a user completes a full team page.
REWARD_PAGE_SATS=210

# Sats awarded when a user completes the entire album.
REWARD_ALBUM_SATS=5000

# ── Nostr relays ──────────────────────────────────────────────────────────────

# Comma-separated list of Nostr relay URLs where game state is published.
NEXT_PUBLIC_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# ── App URL ───────────────────────────────────────────────────────────────────

# Public URL of the deployed app. Used in Nostr share messages.
# Optional — defaults to https://figus.world if unset.
NEXT_PUBLIC_SITE_URL=https://figus.world
